{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,

    // Instructions
    "instructions": ["~/.config/opencode/context7.md"],

    // MCP & Skills
    "mcp": {
      "context7": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp",
        "headers": {
          "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
        },
        "enabled": true
      }
    },
    "skills": {
        "paths": ["~/.config/opencode/skills"]
    },

    // Providers
    "provider": {
        "amazon-bedrock": {
            "options": {
                "region": "eu-west-2",
                "profile": "bedrock"
            }
        }
    },
}
